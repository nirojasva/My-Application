<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="8dp">

    <ImageView
        android:id="@+id/imgMessage"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_bubble_ai"
        android:padding="2dp"/>

    <LinearLayout
        android:id="@+id/thoughtContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginEnd="64dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/btnToggleThought"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▼ Show Reasoning"
            android:textColor="@color/accent_color"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/txtThought"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A20"
            android:padding="8dp"
            android:textColor="#888888"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="64dp"
        android:background="@drawable/bg_bubble_ai"
        android:padding="12dp"
        android:text="AI message"
        android:textColor="@color/text_ai"
        android:textSize="16sp" />
</LinearLayout>
